datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  EMPLOYEE
  ASSET_MANAGER
  DEPARTMENT_HEAD
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ALLOCATED
  RETURNED
  OVERDUE
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditStatus {
  DRAFT
  IN_PROGRESS
  CLOSED
}

enum AuditCondition {
  VERIFIED
  MISSING
  DAMAGED
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  name                String
  role                Role                 @default(EMPLOYEE)
  status              UserStatus           @default(ACTIVE)
  departmentId        String?
  department          Department?          @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headedDepartment    Department?          @relation("DepartmentHead")
  allocations         AssetAllocation[]    @relation("AllocatedTo")
  actionedAllocations AssetAllocation[]    @relation("AllocatedBy")
  transfersFrom       TransferRequest[]    @relation("TransferSource")
  transfersTo         TransferRequest[]    @relation("TransferTarget")
  transfersApproved   TransferRequest[]    @relation("TransferApprover")
  transfersRequested  TransferRequest[]    @relation("TransferRequester")
  bookings            ResourceBooking[]
  maintenanceRequests MaintenanceRequest[] @relation("Reporter")
  auditedCycles       AuditCycle[]         @relation("Auditor")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Department {
  id             String            @id @default(uuid())
  name           String            @unique
  status         UserStatus        @default(ACTIVE)
  headId         String?           @unique
  head           User?             @relation("DepartmentHead", fields: [headId], references: [id])
  parentId       String?
  parent         Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  subDepartments Department[]      @relation("DepartmentHierarchy")
  employees      User[]            @relation("DepartmentEmployees")
  allocations    AssetAllocation[]
  assets         Asset[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model AssetCategory {
  id           String   @id @default(uuid())
  name         String   @unique
  customFields Json? // Array of { name: string, type: 'string' | 'number' | 'boolean', required: boolean }
  assets       Asset[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Asset {
  id                  String               @id @default(uuid())
  name                String
  assetTag            String               @unique // AF-0001, etc.
  serialNumber        String               @unique
  categoryId          String
  category            AssetCategory        @relation(fields: [categoryId], references: [id])
  acquisitionDate     DateTime
  acquisitionCost     Float
  condition           String // New, Good, Fair, Poor
  location            String
  isBookable          Boolean              @default(false)
  status              AssetStatus          @default(AVAILABLE)
  departmentId        String?
  department          Department?          @relation(fields: [departmentId], references: [id])
  customValues        Json? // Dynamic category specific values { "warrantyPeriod": 24 }
  allocations         AssetAllocation[]
  bookings            ResourceBooking[]
  maintenanceRequests MaintenanceRequest[]
  auditResults        AuditAssetResult[]
  transfers           TransferRequest[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model AssetAllocation {
  id                 String           @id @default(uuid())
  assetId            String
  asset              Asset            @relation(fields: [assetId], references: [id])
  userId             String
  user               User             @relation("AllocatedTo", fields: [userId], references: [id])
  departmentId       String?
  department         Department?      @relation(fields: [departmentId], references: [id])
  allocatedById      String
  allocatedBy        User             @relation("AllocatedBy", fields: [allocatedById], references: [id])
  allocatedAt        DateTime         @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  notes              String?
  status             AllocationStatus @default(ALLOCATED)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model TransferRequest {
  id            String         @id @default(uuid())
  assetId       String
  asset         Asset          @relation(fields: [assetId], references: [id])
  sourceUserId  String
  sourceUser    User           @relation("TransferSource", fields: [sourceUserId], references: [id])
  targetUserId  String
  targetUser    User           @relation("TransferTarget", fields: [targetUserId], references: [id])
  requestedById String
  requestedBy   User           @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?          @relation("TransferApprover", fields: [approvedById], references: [id])
  status        TransferStatus @default(PENDING)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ResourceBooking {
  id        String        @id @default(uuid())
  assetId   String
  asset     Asset         @relation(fields: [assetId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(UPCOMING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model MaintenanceRequest {
  id                 String            @id @default(uuid())
  assetId            String
  asset              Asset             @relation(fields: [assetId], references: [id])
  reporterId         String
  reporter           User              @relation("Reporter", fields: [reporterId], references: [id])
  description        String
  priority           String // Low, Medium, High, Critical
  technicianAssigned String?
  status             MaintenanceStatus @default(PENDING)
  resolutionNotes    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model AuditCycle {
  id           String             @id @default(uuid())
  name         String
  departmentId String?
  location     String?
  startDate    DateTime
  endDate      DateTime
  status       AuditStatus        @default(DRAFT)
  auditorId    String
  auditor      User               @relation("Auditor", fields: [auditorId], references: [id])
  results      AuditAssetResult[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model AuditAssetResult {
  id           String         @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle     @relation(fields: [auditCycleId], references: [id])
  assetId      String
  asset        Asset          @relation(fields: [assetId], references: [id])
  condition    AuditCondition
  notes        String?
  checkedAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([auditCycleId, assetId])
}
